    "corpus": "tsx tests/corpus.ts",
    "groundtruth": "tsx tests/groundtruth.ts"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@google/genai": "^0.9.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
