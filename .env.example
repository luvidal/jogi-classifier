# Required only for manual harnesses/playground.
# Production host apps own Gemini auth and inject geminiCall; src/ never reads keys.
# Do not add geminiKey/apiKey to configure(); wrap auth in the host's geminiCall.
GEMINI_API_KEY=

# Alternative to GEMINI_API_KEY for Vertex AI.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Defaults shown here match the local Jogi checkout.
JOGI_DOCTYPES=/Users/avd/GitHub/jogi/data/doctypes.json
CORPUS_ROOT=/Users/avd/Downloads/docs

# Local playground server.
PORT=4177
